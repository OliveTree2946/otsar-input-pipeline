# Claude API key for parsing
ANTHROPIC_API_KEY=

# GitHub personal access token with `repo` scope for committing to AgenticOS vault
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Shared secret required in x-pipeline-secret header on all /api/* calls.
# PIPELINE_SECRET is the server-side source of truth.
# NEXT_PUBLIC_PIPELINE_SECRET is exposed to the client so it can attach the header.
# Keep the two values identical. This is not a real auth boundary — it only
# blocks drive-by traffic to a single-user deployment.
PIPELINE_SECRET=
NEXT_PUBLIC_PIPELINE_SECRET=
